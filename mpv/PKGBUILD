pkgname=(mpv-dev mpv-git)
pkgver=0.41.0
pkgrel=1
pkgdesc='a free, open source, and cross-platform media player'
arch=('x86_64')
url='https://mpv.io/'
makedepends=("libjpeg-dev"
             "libpng-dev"
             "ffmpeg-dev"
             "luajit2-dev" 
             "freetype2-dev"
             "fribidi-dev"
             "harfbuzz-dev"
             "libarchive-dev"
             "libass-dev"
             "lcms2-dev"
             "libbluray-dev"
             "libplacebo-dev"
             "shaderc-dev"
             "spirv-cross-dev"
             "subrandr-dev"
             "vulkan-dev"
             "zlib-dev")
license=('GPL3')
source=("git+https://github.com/mpv-player/mpv.git")
md5sums=('SKIP')

build() {
  LDFLAGS+=" -luserenv"
  cd $srcdir/mpv
  NO_CONFLTO=1 meson setup build \
    --prefix="${MINGW_PREFIX}" \
    --libdir=${MINGW_PREFIX}/lib \
    --cross-file=../../../cross.meson \
    -Doptimization=3 \
    -Db_lto=true \
    -Db_lto_mode=thin \
    -Dlibmpv=false \
    -Dlua=enabled \
    -Djavascript=disabled \
    -Dsdl2-gamepad=disabled \
    -Dsubrandr=enabled \
    -Dlibarchive=enabled \
    -Dlibbluray=enabled \
    -Ddvdnav=disabled \
    -Drubberband=disabled \
    -Dlcms2=enabled \
    -Dopenal=disabled \
    -Dspirv-cross=enabled \
    -Dvulkan=enabled \
    -Dvapoursynth=disabled \
    -Degl-angle=disabled
  LTO_JOB=1 PDB=1 meson compile -C build
  
  # get latest commit sha
  short_sha=$(git rev-parse --short HEAD)
  echo $short_sha > SHORT_SHA
}

package_mpv-dev() {
  cd $srcdir/mpv
  DESTDIR=$pkgdir meson install -C build
}

package_mpv-git() {
  export PKGEXT='.pkg.tar.xz'
  mkdir -p $pkgdir${MINGW_PREFIX}/mpv
  cd $srcdir/mpv/build
  mv mpv.exe $pkgdir${MINGW_PREFIX}/mpv
  mv mpv.com $pkgdir${MINGW_PREFIX}/mpv
  ${TARGET_ARCH}-strip -s $pkgdir${MINGW_PREFIX}/mpv/mpv.*
  mv ../SHORT_SHA $pkgdir${MINGW_PREFIX}/mpv
}
