pkgname=(ffmpeg-dev ffmpeg-git)
pkgver=8.1
pkgrel=1
pkgdesc='Complete and free Internet live audio and video solution'
arch=('x86_64')
url="http://ffmpeg.org/"
makedepends=("bzip2-dev"
             "dav1d-dev"
             "ffnvcodec-dev"
             "lcms2-dev"
             "libbs2b-dev"
             "libjxl-dev"
             "libplacebo-dev"
             "libsoxr-dev"
             "libwebp-dev"
             "libxml2-dev"
             "libzimg-dev"
             "openssl-dev"
             "shaderc-dev"
             "svtav1-dev")
license=('LGPL')
source=("git+https://github.com/FFmpeg/FFmpeg")
md5sums=('SKIP')

package_ffmpeg-dev() {
  cd $srcdir/FFmpeg
  # fix checks for small buffers
  curl -OL https://patch-diff.githubusercontent.com/raw/eko5624/FFmpeg/pull/3.patch
  patch -p1 -i 3.patch

  NO_CONFLTO=1 ./configure$FFMPEG_LTO \
    --cross-prefix=${TARGET_ARCH}- \
    --prefix=${MINGW_PREFIX} \
    --arch=x86_64 \
    --target-os=mingw32 \
    --target-exec=wine \
    --pkg-config-flags=--static \
    --enable-cross-compile \
    --enable-runtime-cpudetect \
    --disable-debug \
    --disable-doc \
    --enable-gpl \
    --enable-version3 \
    --disable-ffplay \
    --disable-ffprobe \
    --disable-avdevice \
    --disable-pthreads \
    --enable-w32threads \
    --extra-libs="${ffmpeg_extra_libs}" \
    --extra-ldflags="${ffmpeg_extra_ldflags}" \
    --disable-mediafoundation \
    --disable-amf \
    --disable-avisynth \
    --enable-cuvid${ffmpeg_cuda_llvm} \
    --enable-lcms2 \
    --disable-libaom \
    --disable-libaribcaption \
    --enable-libbs2b \
    --enable-libdav1d \
    --disable-libdavs2 \
    --enable-libjxl \
    --disable-libvpl \
    --disable-libmodplug \
    --disable-libmp3lame \
    --disable-libmysofa \
    --disable-libopenmpt \
    --disable-libopus \
    --enable-libplacebo \
    --enable-libsvtav1 \
    --enable-libshaderc \
    --enable-libsoxr \
    --disable-libspeex \
    --disable-libsrt \
    --disable-libssh \
    --disable-libuavs3d \
    --disable-libvorbis \
    --disable-libvpx \
    --enable-libwebp \
    --enable-libxml2 \
    --disable-libxvid \
    --enable-libzimg \
    --disable-libzvbi \
    --disable-openal \
    --disable-opengl \
    --enable-openssl \
    --enable-nvdec \
    --enable-nvenc \
    --disable-vaapi \
    --disable-vapoursynth \
    --disable-videotoolbox \
    --disable-decoder=libaom_av1 \
    --disable-decoder=libvorbis \
    --disable-decoder=libopus \
    --disable-encoder=opus \
    --disable-encoder=vorbis \
    --disable-vdpau
  make DESTDIR=$pkgdir install
  rm -rf $pkgdir${MINGW_PREFIX}/bin $pkgdir${MINGW_PREFIX}/share $pkgdir${MINGW_PREFIX}/lib/*.def
}

package_ffmpeg-git() {
  export PKGEXT='.pkg.tar.xz'
  mkdir -p $pkgdir${MINGW_PREFIX}/ffmpeg
  cd $srcdir/FFmpeg
  make DESTDIR=$pkgdir install
  rm -rf $pkgdir${MINGW_PREFIX}/bin/*.lib $pkgdir${MINGW_PREFIX}/share $pkgdir${MINGW_PREFIX}/include $pkgdir${MINGW_PREFIX}/lib
  strip $pkgdir${MINGW_PREFIX}/bin/*
  mv $pkgdir${MINGW_PREFIX}/bin/ffmpeg.exe $pkgdir${MINGW_PREFIX}/ffmpeg
  rm -rf $pkgdir${MINGW_PREFIX}/bin

  # get latest commit sha
  short_sha=$(git rev-parse --short HEAD)
  echo $short_sha > SHORT_SHA
  mv SHORT_SHA $pkgdir${MINGW_PREFIX}/ffmpeg
}
